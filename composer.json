{
  "name": "stories/api",
  "description": "Stories board game API on PHP + Slim",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "doctrine/dbal": "^4.0",
    "vlucas/phpdotenv": "^5.6",
    "php-di/php-di": "^7.1",
    "php-di/slim-bridge": "^3.4",
    "cboden/ratchet": "^0.4.4",
    "yiisoft/validator": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stories\\": "src/"
    }
  },
  "scripts": {
    "serve": "php -S 0.0.0.0:8080 -t public",
    "migrate": "php bin/migrate.php",
    "ws:serve": "php bin/ws-server.php",
    "frontend:build": "npm --prefix frontend run build"
  }
}
